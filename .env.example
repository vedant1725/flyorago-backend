# ==============================================================================
# Django Core & Security Settings
# ==============================================================================
# Set to False in production
DEBUG=False

# Generate a strong secret key for production (e.g. using openssl rand -hex 32)
SECRET_KEY=your-django-production-secret-key

# Comma-separated list of allowed hostnames (e.g., your-app.onrender.com,flyorago.me)
ALLOWED_HOSTS=localhost,127.0.0.1,flyorago-backend.onrender.com,flyorago.me,www.flyorago.me

# Set logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# ==============================================================================
# Database Configuration (Supabase / Render PostgreSQL)
# ==============================================================================
# For Render Production (using the connection pooler URL from Supabase)
DATABASE_URL=postgresql://postgres:[password]@[pooler-host]:6543/postgres?sslmode=require

# Fallback individual settings (primarily for local development)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=flyorago
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# Redis / Celery / WebSockets Configuration (Optional in Production)
# ==============================================================================
# If left blank, Celery will run tasks in-process (synchronously), and Channels will use memory
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==============================================================================
# CORS & CSRF Origins (Vercel Frontend Integration)
# ==============================================================================
# Set to False to restrict API access in production
CORS_ALLOW_ALL_ORIGINS=False

# Comma-separated trusted frontend origins for CORS (no trailing slash)
CORS_ALLOWED_ORIGINS=https://flyorago.me,https://www.flyorago.me,http://localhost:5173

# Comma-separated trusted origins for CSRF verification (must include scheme)
CSRF_TRUSTED_ORIGINS=https://flyorago.me,https://www.flyorago.me,https://flyorago-backend.onrender.com

# ==============================================================================
# JWT Authentication Configuration
# ==============================================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ==============================================================================
# Cloudinary Storage Configuration
# ==============================================================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ==============================================================================
# SSL & Cookie Security (Defaults to True in production if DEBUG=False)
# ==============================================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
